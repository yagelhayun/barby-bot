NODE_ENV=development
LOG_LEVEL=debug

# Database (Supabase)
DATABASE_HOST=
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=
DATABASE_PASSWORD=

# Telegram - Owner user account (gramjs, used for group management)
OWNER_TG_USER_ID=
OWNER_TG_API_ID=
OWNER_TG_API_HASH=
OWNER_TG_STRING_SESSION=

# Telegram - Admin bot (receives commands from owner)
ADMIN_BOT_TOKEN=
ADMIN_BOT_USERNAME=
ADMIN_BOT_API_AUTH_TOKEN=

# Telegram - Notifications bot (sends alerts to artist groups)
NOTIFICATIONS_BOT_TOKEN=
NOTIFICATIONS_BOT_USERNAME=

# Health check chat ID (group that receives "no shows" pings)
HEALTH_CHAT_ID=
